# 本地部署环境配置
NODE_ENV=production
PORT=3000

# 数据库配置 (SQLite for local deployment)
DB_DIALECT=sqlite
DB_STORAGE=./data/errorbook.sqlite

# JWT认证
JWT_SECRET=your_strong_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# 服务器配置
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# 日志配置
LOG_LEVEL=info

# 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379